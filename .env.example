# ================================================
# NICE JOYERÍA — Variables de entorno
# ================================================
# Copia este archivo como .env.local y llena los valores
# En Hostinger: usa "Import .env" en la pantalla de variables

# -----------------------------------------------
# BASE DE DATOS (Hostinger PostgreSQL)
# -----------------------------------------------
DATABASE_URL=postgresql://usuario:password@localhost:5432/nice_joyeria

# -----------------------------------------------
# ADMIN
# -----------------------------------------------
# Mínimo 32 caracteres — inventa una frase larga
ADMIN_SECRET_KEY=

# Diferente a ADMIN_SECRET_KEY — otra frase larga
JWT_SECRET=

# -----------------------------------------------
# CIFRADO DE DIRECCIONES DE ENVÍO
# -----------------------------------------------
# Genera con este comando en tu terminal:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# -----------------------------------------------
# POLYGON
# -----------------------------------------------
POLYGON_RPC_URL=https://polygon-rpc.com

# Tu wallet de Polygon que recibirá los pagos
STORE_WALLET_ADDRESS=

# Tokens — no cambiar
CNKT_TOKEN_ADDRESS=0x87bdfbe98ba55104701b2f2e999982a317905637
USDT_TOKEN_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# -----------------------------------------------
# PRECIO CNKT+ (solo fallback de emergencia)
# -----------------------------------------------
# El precio real se obtiene automáticamente de GeckoTerminal.
# Este valor SOLO se usa si GeckoTerminal y CoinGecko fallan.
CNKT_PRICE_USD=0.0012

# -----------------------------------------------
# TIPO DE CAMBIO MXN (solo fallback de emergencia)
# -----------------------------------------------
# El tipo de cambio real se obtiene de open.er-api.com.
# Este valor SOLO se usa si esa API falla.
MXN_TO_USD_FALLBACK=0.058

# -----------------------------------------------
# ENVÍOS — configurable también desde el panel admin
# -----------------------------------------------
SHIPPING_MX_MXN=180
SHIPPING_US_USD=0

# -----------------------------------------------
# FRONTEND (variables públicas — empiezan con NEXT_PUBLIC_)
# -----------------------------------------------
# Obtener gratis en: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Tu wallet de Polygon (mismo valor que STORE_WALLET_ADDRESS)
NEXT_PUBLIC_STORE_WALLET=

# Tokens — no cambiar
NEXT_PUBLIC_CNKT_ADDRESS=0x87bdfbe98ba55104701b2f2e999982a317905637
NEXT_PUBLIC_USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# Nombre de la tienda
NEXT_PUBLIC_STORE_NAME=Nice Joyería

